<Window x:Class="Codeagogo.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Codeagogo"
        Width="520" Height="730"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        Icon="Assets/app.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hero banner -->
        <Border Grid.Row="0" Background="#1A5276" Padding="32,24">
            <StackPanel>
                <Border Width="80" Height="80" CornerRadius="16" Margin="0,0,0,12"
                        ClipToBounds="True">
                    <Image Source="Assets/icon-256.png"
                           Width="80" Height="80"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <TextBlock Text="Codeagogo"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Clinical terminology at your fingertips"
                           FontSize="14"
                           Foreground="#B0D4E8"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content - no scroll, everything fits -->
        <StackPanel Grid.Row="1" Margin="32,20,32,12">
            <TextBlock Text="Look up SNOMED CT, LOINC, ICD-10, and RxNorm codes instantly from any application using global hotkeys."
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="#333333"
                       LineHeight="19"
                       Margin="0,0,0,18"/>

            <!-- Stay in the loop card -->
            <Border Background="#F0F7FB" CornerRadius="6" Padding="16,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Stay in the loop"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#1A5276"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Join the Codeagogo mailing list to hear about new features, updates, and tips. Low volume, no spam, unsubscribe any time."
                               TextWrapping="Wrap"
                               FontSize="12.5"
                               Foreground="#555555"
                               LineHeight="18"
                               Margin="0,0,0,10"/>
                    <Button Content="Subscribe to the mailing list"
                            Click="JoinMailingList_Click"
                            Height="34"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="#2980B9"
                                        CornerRadius="4"
                                        Padding="16,0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#1A6FA0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- GitHub card -->
            <Border Background="#F7F5F0" CornerRadius="6" Padding="16,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Help others discover Codeagogo"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#5D4E37"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="A GitHub star helps other clinicians and developers find this tool. It only takes a second and makes a real difference."
                               TextWrapping="Wrap"
                               FontSize="12.5"
                               Foreground="#555555"
                               LineHeight="18"
                               Margin="0,0,0,10"/>
                    <Button Content="Star on GitHub"
                            Click="StarOnGitHub_Click"
                            Height="34"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="#6C757D"
                                        CornerRadius="4"
                                        Padding="16,0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#565E64"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Feedback card -->
            <Border Background="#F5F0F7" CornerRadius="6" Padding="16,12" Margin="0,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Got feedback?"
                                   FontSize="13.5"
                                   FontWeight="SemiBold"
                                   Foreground="#4A3660"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Request features or report issues on GitHub."
                                   FontSize="12"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Click="ReportIssue_Click"
                            Height="32"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="White"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="14,0">
                                    <TextBlock Text="Open Issues"
                                               VerticalAlignment="Center"
                                               FontSize="12.5"
                                               Foreground="#333333"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Padding="32,12,32,14">
            <StackPanel>
                <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start Codeagogo with Windows"
                         IsChecked="True" Margin="0,0,0,10" FontSize="12"/>
                <TextBlock Text="No personal data is collected. The mailing list is managed by CSIRO."
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="#999999"
                           Margin="0,0,0,10"/>
                <Button Content="Get Started"
                        Click="GetStarted_Click"
                        HorizontalAlignment="Stretch"
                        Height="36"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
