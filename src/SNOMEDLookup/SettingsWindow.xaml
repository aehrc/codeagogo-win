<Window x:Class="SNOMEDLookup.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SNOMED Lookup Settings"
        Width="480" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hotkey Configuration -->
        <GroupBox Grid.Row="0" Header="Hotkey Configuration" Padding="8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Current Hotkey:" Margin="0,0,0,4"/>
                <TextBox x:Name="HotkeyTextBox"
                         IsReadOnly="True"
                         PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                         Background="#F5F5F5"
                         Padding="8"
                         FontSize="14"
                         Text="Press a key combination..."/>
                <TextBlock Text="Press a key combination (e.g., Ctrl+Shift+L)"
                           Foreground="Gray"
                           FontSize="11"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- FHIR Endpoint -->
        <GroupBox Grid.Row="1" Header="FHIR Endpoint" Padding="8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Base URL:" Margin="0,0,0,4"/>
                <TextBox x:Name="FhirBaseUrlTextBox"
                         Padding="8"
                         FontSize="13"/>
                <TextBlock Text="FHIR terminology server base URL (e.g., https://tx.ontoserver.csiro.au/fhir)"
                           Foreground="Gray"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Logging -->
        <GroupBox Grid.Row="2" Header="Logging" Padding="8" Margin="0,0,0,12">
            <StackPanel>
                <CheckBox x:Name="DebugLoggingCheckBox"
                          Content="Enable debug logging"
                          Margin="0,0,0,8"/>
                <TextBlock Text="Debug logging provides detailed information for troubleshooting."
                           Foreground="Gray"
                           FontSize="11"
                           Margin="0,0,0,8"/>
                <Button x:Name="ExportDiagnosticsButton"
                        Content="Export Diagnostics..."
                        Click="ExportDiagnostics_Click"
                        HorizontalAlignment="Left"
                        Padding="12,6"/>
            </StackPanel>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="90" Margin="0,0,8,0" Click="Cancel_Click">Cancel</Button>
            <Button x:Name="SaveButton" Width="90" Click="Save_Click">Save</Button>
        </StackPanel>
    </Grid>
</Window>
