<Window x:Class="Codeagogo.EvaluateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ECL Evaluation"
        Width="620" Height="500"
        WindowStyle="ToolWindow"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Icon="Assets/app.ico"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ECL Expression header -->
        <Border Grid.Row="0" Background="#F0F4F8" Padding="10,8" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ExpressionText"
                         Grid.Column="0"
                         Text="{Binding Expression, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MaxHeight="60"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#333"/>
                <ToggleButton x:Name="FsnToggle"
                              Grid.Column="1"
                              Content="FSN"
                              IsChecked="{Binding ShowFsn}"
                              VerticalAlignment="Top"
                              Padding="8,3"
                              FontSize="11"
                              Margin="6,0,0,0"
                              ToolTip="Toggle between Preferred Term and Fully Specified Name"/>
            </Grid>
        </Border>

        <!-- Warnings banner -->
        <ItemsControl x:Name="WarningsBanner" Grid.Row="1"
                      ItemsSource="{Binding Warnings}"
                      Visibility="Collapsed">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#FFF3CD" Padding="8,4" BorderBrush="#FFE69C" BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding}" Foreground="#856404" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Total count bar -->
        <Border Grid.Row="2" Background="#F8F8F8" Padding="10,6" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <TextBlock x:Name="TotalText" FontSize="12" Foreground="#666"/>
        </Border>

        <!-- Loading indicator -->
        <Grid Grid.Row="3" x:Name="LoadingPanel" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Evaluating..." FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
            </StackPanel>
        </Grid>

        <!-- Error display -->
        <Border Grid.Row="3" x:Name="ErrorPanel" Visibility="Collapsed" Padding="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Evaluation Failed" FontSize="16" FontWeight="SemiBold" Foreground="#C0392B" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="ErrorText" TextWrapping="Wrap" Foreground="#666" FontSize="12" HorizontalAlignment="Center" MaxWidth="400"/>
            </StackPanel>
        </Border>

        <!-- Results grid -->
        <DataGrid Grid.Row="3" x:Name="ResultsList" Visibility="Collapsed"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="None"
                  BorderThickness="0" CanUserReorderColumns="False"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  RowHeaderWidth="0" FontSize="12">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Code" Width="Auto" MinWidth="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="4,2">
                                <Hyperlink Click="ConceptCode_Click" ToolTip="Open in Shrimp browser">
                                    <Run Text="{Binding Code, Mode=OneWay}"/>
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Display" Binding="{Binding Display}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="Margin" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Tag" Binding="{Binding SemanticTag}" Width="Auto" MinWidth="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#999"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Margin" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Diagram" Click="DiagramButton_Click"
                                    Padding="6,1" FontSize="11" HorizontalAlignment="Left"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open in Shrimp" Click="ContextShrimp_Click"/>
                    <MenuItem Header="Copy Code" Click="ContextCopyCode_Click"/>
                    <MenuItem Header="Copy Display" Click="ContextCopyDisplay_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Window>
