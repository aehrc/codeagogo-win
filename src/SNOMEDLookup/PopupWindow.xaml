<Window x:Class="SNOMEDLookup.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Border CornerRadius="10" Background="#EE1E1E1E" Padding="12">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"/>
            <TextBlock x:Name="SubtitleText" Margin="0,6,0,0" FontSize="12" Foreground="#DDDDDD" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
