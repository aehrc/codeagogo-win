<Window x:Class="Codeagogo.ECLReferenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ECL Reference"
        Width="520" Height="600"
        MinWidth="380" MinHeight="350"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        Icon="Assets/app.ico"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with search -->
        <Border Grid.Row="0" Padding="12,10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <StackPanel>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="ECL Reference" FontSize="15" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="TopicCount" FontSize="11" Foreground="#999"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </DockPanel>
                <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"
                         FontSize="12" Padding="6,4">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  Filter..." Foreground="#AAA" FontSize="12" Margin="4,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </Border>

        <!-- Article list -->
        <TreeView Grid.Row="1" x:Name="ArticleTree" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Hyperlink Click="SpecLink_Click">ECL Specification</Hyperlink>
                </TextBlock>
                <Button Content="Close" Click="Close_Click" DockPanel.Dock="Right"
                        Padding="12,4" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
