<Window x:Class="Codeagogo.Visualization.VisualizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Concept Diagram" Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Icon="/Assets/app.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock x:Name="TitleText" Text="Concept Diagram"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SubtitleText" Text=""
                               Foreground="#AAAAAA" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#x2212;" Width="32" Height="32" Margin="4,0"
                            Click="ZoomOut_Click" ToolTip="Zoom Out"
                            Background="#3D3D3D" Foreground="White" BorderThickness="0"
                            FontSize="16" FontWeight="Bold"/>
                    <Button Content="100%" Width="48" Height="32" Margin="4,0"
                            Click="ZoomReset_Click" ToolTip="Reset Zoom" x:Name="ZoomLabel"
                            Background="#3D3D3D" Foreground="White" BorderThickness="0"
                            FontSize="11"/>
                    <Button Content="+" Width="32" Height="32" Margin="4,0"
                            Click="ZoomIn_Click" ToolTip="Zoom In"
                            Background="#3D3D3D" Foreground="White" BorderThickness="0"
                            FontSize="16" FontWeight="Bold"/>
                    <Border Width="1" Background="#444" Margin="8,4"/>
                    <Button Content="💾 SVG" Width="60" Height="32" Margin="4,0"
                            Click="SaveSvg_Click" ToolTip="Save as SVG"
                            Background="#3D3D3D" Foreground="White" BorderThickness="0"
                            FontSize="11"/>
                    <Button Content="💾 PNG" Width="60" Height="32" Margin="4,0"
                            Click="SavePng_Click" ToolTip="Save as PNG"
                            Background="#3D3D3D" Foreground="White" BorderThickness="0"
                            FontSize="11"/>
                    <Border Width="1" Background="#444" Margin="8,4"/>
                    <Button Content="📋 Copy" Width="70" Height="32" Margin="4,0"
                            Click="CopyToClipboard_Click" ToolTip="Copy diagram to clipboard as PNG"
                            Background="#3D3D3D" Foreground="White" BorderThickness="0"
                            FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- WebView2 for SVG display -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>

        <!-- Loading overlay -->
        <Border x:Name="LoadingOverlay" Grid.Row="1"
                Background="#CC1E1E1E" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,12"/>
                <TextBlock x:Name="LoadingStatusText" Text="Loading concept properties..."
                           Foreground="#AAAAAA" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error overlay -->
        <Border x:Name="ErrorOverlay" Grid.Row="1"
                Background="#CC1E1E1E" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Error" Foreground="#FF6B6B" FontSize="18"
                           FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="ErrorText" Foreground="#DDDDDD" FontSize="13"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#2D2D2D" Padding="12,4">
            <TextBlock x:Name="StatusText" Text="" Foreground="#888888" FontSize="11"/>
        </Border>
    </Grid>
</Window>
